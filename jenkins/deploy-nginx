# nginx ingress

apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  annotations:
    alb.ingress.kubernetes.io/listen-ports: '[{"HTTP":80},{"HTTPS":443}]'
  name: app-ingress
  namespace: default
spec:
  ingressClassName: alb
  rules:
    - host: blog.jsonjsonstart.dpdns.org
      http:
        paths:
          - backend:
              service:
                name: nginx-svc
                port:
                  number: 80
            path: /
            pathType: Prefix

