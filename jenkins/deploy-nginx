# 修改ingress增加证书tls
root@chasel:~/ack# cat nginx-ingress.yaml
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  annotations:
    alb.ingress.kubernetes.io/listen-ports: '[{"HTTP":80},{"HTTPS":443}]'
    alb.ingress.kubernetes.io/ssl-redirect: "true"  # HTTP 重定向到 HTTPS
  name: app-ingress
  namespace: default
spec:
  ingressClassName: alb
  tls:
    - hosts:
        - blog.jsonjsonstart.dpdns.org
      secretName: blog-dpdns-org-tls
  rules:
    - host: blog.jsonjsonstart.dpdns.org
      http:
        paths:
          - backend:
              service:
                name: nginx-svc
                port:
                  number: 80
            path: /
            pathType: Prefix

