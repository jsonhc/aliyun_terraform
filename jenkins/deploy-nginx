root@chasel:~/ack# cat cluster-issuer.yaml
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: letsencrypt-cloudflare
spec:
  acme:
    # Let's Encrypt 生产环境
    server: https://acme-v02.api.letsencrypt.org/directory

    email: jsonjsonstart@gmail.com  # 替换为你的邮箱

    privateKeySecretRef:
      name: letsencrypt-cloudflare-account-key

    solvers:
    - dns01:
        cloudflare:
          apiTokenSecretRef:
            name: cloudflare-api-token
            key: api-token
      # 可选：指定哪些域名使用此 solver
      selector:
        dnsNames:
        - "blog.jsonjsonstart.dpdns.org"

