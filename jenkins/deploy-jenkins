                   )
                }
            }
        }
        stage('Build & Push Image') {
            steps {
                container('docker') {
                    script {
                        def imageTag = "${env.BUILD_NUMBER}"
                        def imageFullName = "${REGISTRY}/${NAMESPACE}/${IMAGE_NAME}:${imageTag}"
                        
                        sh """
                            docker build -t ${imageFullName} .
                            docker login --username=\${ACR_USERNAME} --password=\${ACR_PASSWORD} ${REGISTRY}
                            docker push ${imageFullName}
                        """
